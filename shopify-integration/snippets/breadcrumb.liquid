        <path d="M0.0433226 1.48333L0.927489 0.6L5.74332 5.41417C5.82095 5.49131 5.88256 5.58304 5.9246 5.68408C5.96664 5.78512 5.98828 5.89348 5.98828 6.00292C5.98828 6.11235 5.96664 6.22071 5.9246 6.32175C5.88256 6.4228 5.82095 6.51453 5.74332 6.59167L0.927489 11.4083L0.0441556 10.525L4.56416 6.00417L0.0433226 1.48333Z" fill="black"/>
      </svg>
      <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a>
    {% endif %}
    <svg xmlns="http://www.w3.org/2000/svg" width="6" height="12" viewBox="0 0 6 12" fill="none">
        <path d="M0.0433226 1.48333L0.927489 0.6L5.74332 5.41417C5.82095 5.49131 5.88256 5.58304 5.9246 5.68408C5.96664 5.78512 5.98828 5.89348 5.98828 6.00292C5.98828 6.11235 5.96664 6.22071 5.9246 6.32175C5.88256 6.4228 5.82095 6.51453 5.74332 6.59167L0.927489 11.4083L0.0441556 10.525L4.56416 6.00417L0.0433226 1.48333Z" fill="black"/>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}
<div class="custom-product-highlight-section {{ section.settings.class }} color-{{ section.settings.section_color_scheme }} gradient{% unless section.settings.background_style == 'none' and settings.text_boxes_border_thickness > 0 or settings.text_boxes_shadow_opacity > 0 %} background-{{ section.settings.background_style }}{% endunless %}{% if section.settings.title == blank %} no-heading{% endif %}">
  <div
    class="page-width section-{{ section.id }}-padding isolate{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
    {% if settings.animations_reveal_on_scroll %}
      data-cascade
    {% endif %}
  >
<div class="custom-product-highlight">
  <div class="cph_text_area">
    {% if section.settings.icon %}
      <img class="icon" src="{{ section.settings.icon | image_url: width: 100 }}" alt="Icon" />
    {% endif %}
    <div>
    <div class="subheading">{{ section.settings.subheading }}</div>
    <h2 class="title inline-richtext h1 scroll-trigger animate--slide-in">{{ section.settings.heading }}</h2>
    <div class="description">{{ section.settings.text }}</div>
    </div>
    {% if section.settings.button_link %}
      <a class="view-all link" href="{{ section.settings.button_link }}">
        {{ section.settings.button_label }} 
        <svg xmlns="http://www.w3.org/2000/svg" width="25" height="16" viewBox="0 0 25 16" fill="none">
        <path d="M24.7071 8.90799C25.0976 8.51746 25.0976 7.8843 24.7071 7.49377L18.3431 1.12981C17.9526 0.739283 17.3195 0.739283 16.9289 1.12981C16.5384 1.52034 16.5384 2.15349 16.9289 2.54402L22.5858 8.20088L16.9289 13.8578C16.5384 14.2483 16.5384 14.8814 16.9289 15.272C17.3195 15.6625 17.9526 15.6625 18.3431 15.272L24.7071 8.90799ZM0 9.20088H24V7.20088H0V9.20088Z" fill="#B59A6C"/>
        </svg>
      </a>
    {% endif %}
  </div>

    <div class="owl-carousel owl-theme cph_products_row">
        {%- if section.settings.product_1 != blank -%}
        <div class="cph_products_item">
        {% render 'card-product',
          card_product: section.settings.product_1,
          media_aspect_ratio: section.settings.image_ratio,
          image_shape: section.settings.image_shape,
          show_secondary_image: section.settings.show_secondary_image,
          show_vendor: section.settings.show_vendor,
          show_rating: section.settings.show_rating,
          skip_styles: skip_card_product_styles,
          section_id: section.id,
          quick_add: section.settings.quick_add
        %}
        </div>
        {% endif %}
        {%- if section.settings.product_1 != blank -%}
        <div class="cph_products_item">
        {% render 'card-product',
          card_product: section.settings.product_2,
          media_aspect_ratio: section.settings.image_ratio,
          image_shape: section.settings.image_shape,
          show_secondary_image: section.settings.show_secondary_image,
          show_vendor: section.settings.show_vendor,
          show_rating: section.settings.show_rating,
          skip_styles: skip_card_product_styles,
          section_id: section.id,
          quick_add: section.settings.quick_add
        %}
        </div>
        {% endif %}
        {%- if section.settings.product_3 != blank -%}
        <div class="cph_products_item">
        {% render 'card-product',
          card_product: section.settings.product_3,
          media_aspect_ratio: section.settings.image_ratio,
          image_shape: section.settings.image_shape,
          show_secondary_image: section.settings.show_secondary_image,
          show_vendor: section.settings.show_vendor,
          show_rating: section.settings.show_rating,
          skip_styles: skip_card_product_styles,
          section_id: section.id,
          quick_add: section.settings.quick_add
        %}
        </div>
        {% endif %}
        {%- if section.settings.product_4 != blank -%}
        <div class="cph_products_item">
        {% render 'card-product',
          card_product: section.settings.product_4,
          media_aspect_ratio: section.settings.image_ratio,
          image_shape: section.settings.image_shape,
          show_secondary_image: section.settings.show_secondary_image,
          show_vendor: section.settings.show_vendor,
          show_rating: section.settings.show_rating,
          skip_styles: skip_card_product_styles,
          section_id: section.id,
          quick_add: section.settings.quick_add
        %}
        </div>
        {% endif %}
        </div>
      </div>
      <!-- Custom Nav -->
                <div class="cph_custom_nav custom-nav">
                  <div class="custom-prev">
                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 13 13" fill="none">
                      <path d="M8.20002 2.40005L4.20002 6.40005L8.20002 10.4001" stroke="white"/>
                    </svg>
                    Prev</div>
                  <span class="owl-fraction">1/4</span>
                  <div class="custom-next">Next 
                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 13 13" fill="none">
                      <path d="M4.20007 2.40015L8.20007 6.40015L4.20007 10.4001" stroke="white"/>
                    </svg>
                    </div>
                </div>
</div>
</div>
</div>


{% schema %}
{
  "name": "Custom Product Highlight",
  "tag": "section",
  "class": "custom-product-highlight",
  "settings": [
    {
      "type": "image_picker",
      "id": "icon",
      "label": "Icon"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "SHOP"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Pendants"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Discover our handpicked selection of exquisite jewelry pieces..."
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "View All Trending"
    },
    {
      "type": "product",
      "id": "product_1",
      "label": "Product - 1"
    },
    {
      "type": "product",
      "id": "product_2",
      "label": "Product - 2"
    },
    {
      "type": "product",
      "id": "product_3",
      "label": "Product - 3"
    },
    {
      "type": "product",
      "id": "product_4",
      "label": "Product - 4"
    },
    {
      "type": "header",
      "content": "t:sections.image-with-text.settings.header_colors.content"
    },        
    {
      "type": "color_scheme",
      "id": "section_color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.multirow.settings.container_color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Custom Product Highlight"
    }
  ]
}
{% endschema %}

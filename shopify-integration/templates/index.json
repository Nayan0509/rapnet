9LkULK","featured_collection_xWzDrM","featured_collection_wdnkQQ","featured_collection_6wQkwh","featured_collection_rAzwcE"],"disabled":true,"name":"t:sections.collection-list.presets.name","settings":{"title":"Jewllery Collection","heading_size":"h2","image_ratio":"portrait","columns_desktop":5,"color_scheme":"","show_view_all":false,"columns_mobile":"1","swipe_on_mobile":true,"padding_top":24,"padding_bottom":0}},"multicolumn_B7XnXk":{"type":"multicolumn","blocks":{"column_tTdPPp":{"type":"column","settings":{"image":"shopify:\/\/shop_images\/material-symbols-light_diamond-outline.svg","title":"1. Choose your diamonds","text":"","link_label":"","link":""}},"column_MFatBY":{"type":"column","settings":{"image":"shopify:\/\/shop_images\/Frame_1.svg","title":"1. Choose your Setting","text":"","link_label":"","link":""}},"column_xBxUze":{"type":"column","settings":{"image":"shopify:\/\/shop_images\/noun-diamond-ring-7809095_1.svg","title":"3. view completed","text":"","link_label":"","link":""}}},"block_order":["column_tTdPPp","column_MFatBY","column_xBxUze"],"disabled":true,"name":"How it works","settings":{"class":"how_it_works","title":"How it works","heading_size":"h1","image_width":"third","image_ratio":"square","button_label":"","button_link":"","columns_desktop":3,"column_alignment":"center","background_style":"none","color_scheme":"","columns_mobile":"1","swipe_on_mobile":false,"padding_top":60,"padding_bottom":60}},"image_with_text_qBxqr9":{"type":"image-with-text","blocks":{"heading_XQ39hz":{"type":"heading","settings":{"heading":"Why Us?","heading_size":"h1"}},"text_igHHbg":{"type":"text","settings":{"text":"<p>Access the Diamond Market — Without Retail Markups<br\/><br\/>For generations, the diamond trade has operated behind closed doors — with pricing structures most customers never see.<br\/>At Soulique, we change that.<br\/>We give you direct access to the same global diamond market that jewelers buy from — without inflated showroom margins, branding premiums, or hidden commissions.<br\/>You don’t pay retail.<br\/>You pay market.<br\/>Every diamond we offer is:<br\/>- Independently certified (GIA \/ IGI)<br\/>- Transparently priced<br\/>- Carefully sourced from trusted global suppliers<br\/>- Backed by documentation and clarity reports<br\/>When you work with Soulique, you’re not walking into a jewelry store.<br\/>You’re stepping into the diamond trade itself.<\/p>","text_style":"body"}},"more_info_98U388":{"type":"more_info","settings":{"image_1":"shopify:\/\/shop_images\/rap_round_1.svg","heading_1":"","text_1":"<p>Direct-from-source pricing — pay what a jeweler would pay.<\/p>","image_2":"shopify:\/\/shop_images\/rap_marquise_1.svg","heading_2":"","text_2":"<p>All diamonds independently graded and certified.<\/p>","image_3":"shopify:\/\/shop_images\/rap_pear_1.svg","heading_3":"","text_3":"<p>No hidden markups or commissions.<\/p>","heading_4":"","text_4":""}}},"block_order":["heading_XQ39hz","text_igHHbg","more_info_98U388"],"name":"Why Us?","settings":{"class":"why_us","image":"shopify:\/\/shop_images\/IMG_4005.jpg","height":"adapt","desktop_image_width":"small","layout":"image_first","image_behavior":"none","content_layout":"no-overlap","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left","section_color_scheme":"scheme-1","color_scheme":"","padding_top":60,"padding_bottom":60}},"image_banner_qPVhbb":{"type":"image-banner","blocks":{"text_RHtDAA":{"type":"text","settings":{"text":"Rind Made With Soulique Diamond Total Cost = 1.35 Lakhs Choose your own diamond with specific grading.","text_style":"body"}},"text_xqNjrz":{"type":"text","settings":{"text":"Rind Made With Other Brands Total Cost - 2.50 Lakhs No Specific Quality and grading.","text_style":"body"}}},"block_order":["text_RHtDAA","text_xqNjrz"],"name":"t:sections.image-banner.presets.name","settings":{"image":"shopify:\/\/shop_images\/IMG_4005.jpg","image_2":"shopify:\/\/shop_images\/IMG_4005.jpg","image_overlay_opacity":0,"image_height":"large","image_behavior":"none","desktop_content_position":"top-center","desktop_content_alignment":"center","show_text_box":true,"color_scheme":"scheme-2","stack_images_on_mobile":true,"mobile_content_alignment":"center","show_text_below":true}},"rich_text_9khBh6":{"type":"rich-text","blocks":{"heading_tkGeqc":{"type":"heading","settings":{"heading":"Understand Soulique Diamond Rating","heading_size":"h1"}},"text_pbaefY":{"type":"text","settings":{"text":"<p><br\/>Diamonds, Made Simple<br\/><br\/>Diamond grading can often feel complex. With multiple factors like colour, clarity, cut and fluorescence, it’s easy to assume that a higher grade always means a better diamond. In reality, that is not always true.<br\/>At Soulique, we believe a diamond should be evaluated as a whole rather than judged only by individual grading factors. Sometimes a G VVS2 diamond with excellent proportions and cut can appear more brilliant and beautiful than an F VVS1 diamond with weaker cut quality.<br\/><strong>For example:<br\/>0.3 Ct Round G VVS2 EX EX EX None — 8.96 Soulique Rating  <br\/>0.3 Ct Round F VVS1 VG VG VG Faint — 7.93 Soulique Rating<br\/><\/strong><br\/>Why the difference?<br\/>Cut plays the most important role in a diamond’s brilliance.  <br\/>An Excellent Cut reflects more light and creates more sparkle compared to a Very Good Cut. Even if the colour or clarity is slightly lower, a well-cut diamond will often look brighter and more beautiful.<br\/>To simplify this for buyers, we created the Soulique Rating — a performance score that evaluates a diamond based on the combined importance of its grading factors and how it truly appears.<br\/>Instead of focusing only on paper grades, the Soulique Rating highlights diamonds that offer the best balance of brilliance, quality and value.<br\/><br\/><strong>Soulique Rating Scale<br\/><\/strong>9+ — Exceptional  <br\/>7–8.9 — Premium  <br\/>5–6.9 — Smart Value  <br\/>Every diamond remains independently certified by GIA or IGI.  <br\/>The Soulique Rating simply helps you understand which diamond will look better — not just which one looks better on paper.<br\/><br\/><strong>How to Use the Soulique Rating<\/strong><br\/>Choose the shape you prefer, select your price range, and compare the Soulique Rating of each diamond. By looking at both the rating and the price difference, you can easily identify the diamond that offers the best brilliance and overall value.<br\/><br\/>With Soulique, choosing the right diamond becomes clearer, simpler and more confident.<\/p>"}}},"block_order":["heading_tkGeqc","text_pbaefY"],"custom_css":[".rich-text__text {margin-top: 0;}"],"name":"Diamond Grading - Rich text","settings":{"desktop_content_position":"center","content_alignment":"left","color_scheme":"scheme-e327dc31-97be-4c47-bb6b-439e55bbec86","full_width":true,"padding_top":80,"padding_bottom":60}},"multicolumn_zTNm4w":{"type":"multicolumn","blocks":{"column_MPBFnr":{"type":"column","settings":{"title":"Colour","text":"<p>DEF<\/p><p>GH<\/p><p>IJK<\/p><p>LM<\/p>","link_label":"","link":""}},"column_cCRHm7":{"type":"column","settings":{"title":"purity","text":"<p>VVS<\/p><p>VS<\/p><p>SI<\/p><p>I1<\/p>","link_label":"","link":""}},"column_qWAabU":{"type":"column","settings":{"title":"cut","text":"<p>EX<\/p><p>VG<\/p><p>GOOD<\/p><p>POOR<\/p>","link_label":"","link":""}},"column_FPHK6W":{"type":"column","settings":{"title":"Fluorescence","text":"<p>NONE<\/p><p>FAINT<\/p><p>MEDIUM<\/p><p>STRONG<\/p>","link_label":"","link":""}},"column_xywC7p":{"type":"column","disabled":true,"settings":{"title":"score","text":"<p>100%<\/p><p>93.75%<\/p><p>87.50%<\/p><p>81.25%<\/p>","link_label":"","link":""}},"column_4BmhjM":{"type":"column","disabled":true,"settings":{"title":"code","text":"<p>DEF-VVS-EX-NONE<\/p><p>DEF-VVS-EX-FAINT<\/p><p>DEF-VVS-EX-MEDIUM<\/p><p>DEF-VVS-EX-STRONG<\/p>","link_label":"","link":""}}},"block_order":["column_MPBFnr","column_cCRHm7","column_qWAabU","column_FPHK
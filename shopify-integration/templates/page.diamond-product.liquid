            Your browser does not support the video tag.
          </video>
        </div>
      </div>

      <!-- Product Info -->
      <div class="product__info-wrapper grid__item scroll-trigger animate--slide-in">
        <div class="product__info-container product__column-sticky">
          
          <!-- Lab Text -->

<style>
  .diamond-product-page {
    padding: 36px 0;
  }
  @media screen and (min-width: 750px) {
    .diamond-product-page {
      padding: 48px 0;
    }
  }
  
  /* Quantity Selector */
  .product-form__quantity {
    margin-bottom: 20px;
  }

  .quantity__label {
    display: block;
    margin-bottom: 12px;
    font-size: 14px;
    font-weight: 500;
  }

  .quantity {
    display: flex;
    align-items: center;
    border: 1px solid #e5e5e5;
    border-radius: 4px;
    max-width: 150px;
  }

  .quantity__button {
    background: transparent;
    border: none;
    padding: 12px 16px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .quantity__button:hover {
    background: #f5f5f5;
  }

  .quantity__input {
    border: none;
    text-align: center;
    width: 60px;
    padding: 12px 8px;
    font-size: 14px;
    font-weight: 500;
    -moz-appearance: textfield;
  }

  .quantity__input::-webkit-outer-spin-button,
  .quantity__input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  /* Inquiry Modal Styles */
  .inquiry-modal {
    display: none;
    position: fixed;
    z-index: 9999;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    overflow: auto;
    background-color: rgba(0, 0, 0, 0.5);
    animation: fadeIn 0.3s ease;
  }

  .inquiry-modal.active {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .inquiry-modal-content {
    background-color: #fff;
    padding: 0;
    border-radius: 8px;
    width: 90%;
    max-width: 500px;
    max-height: 90vh;
    overflow-y: auto;
    animation: slideIn 0.3s ease;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
  }

  .inquiry-modal-header {
    padding: 24px;
    border-bottom: 1px solid #e5e5e5;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .inquiry-modal-header h2 {
    margin: 0;
    font-size: 20px;
    font-weight: 600;
  }

  .inquiry-modal-close {
    background: none;
    border: none;
    font-size: 28px;
    cursor: pointer;
    color: #999;
    padding: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
  }

  .inquiry-modal-close:hover {
    color: #333;
  }

  .inquiry-modal-body {
    padding: 24px;
  }

  .inquiry-form-group {
    margin-bottom: 20px;
  }

  .inquiry-form-group label {
    display: block;
    margin-bottom: 8px;
    font-weight: 500;
    font-size: 14px;
    color: #333;
  }

  .inquiry-form-group input,
  .inquiry-form-group textarea {
    width: 100%;
    padding: 12px;
    border: 1px solid #e5e5e5;
    border-radius: 4px;
    font-size: 14px;
    font-family: inherit;
    transition: border-color 0.2s;
  }

  .inquiry-form-group input:focus,
  .inquiry-form-group textarea:focus {
    outline: none;
    border-color: #333;
  }

  .inquiry-form-group textarea {
    resize: vertical;
    min-height: 100px;
  }

  .inquiry-form-group.required label::after {
    content: " *";
    color: #e74c3c;
  }

  .inquiry-diamond-info {
    background: #f9f9f9;
    padding: 16px;
    border-radius: 4px;
    margin-bottom: 20px;
    font-size: 13px;
  }

  .inquiry-diamond-info h3 {
    margin: 0 0 12px 0;
    font-size: 14px;
    font-weight: 600;
  }

  .inquiry-diamond-info p {
    margin: 4px 0;
    color: #666;
  }

  .inquiry-submit-btn {
    width: 100%;
    padding: 14px;
    background: #333;
    color: #fff;
    border: none;
    border-radius: 4px;
    font-size: 16px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s;
  }

  .inquiry-submit-btn:hover {
    background: #000;
  }

  .inquiry-submit-btn:disabled {
    background: #ccc;
    cursor: not-allowed;
  }

  .inquiry-success-message {
    display: none;
    padding: 16px;
    background: #d4edda;
    color: #155724;
    border: 1px solid #c3e6cb;
    border-radius: 4px;
    margin-bottom: 20px;
  }

  .inquiry-error-message {
    display: none;
    padding: 16px;
    background: #f8d7da;
    color: #721c24;
    border: 1px solid #f5c6cb;
    border-radius: 4px;
    margin-bottom: 20px;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes slideIn {
    from { transform: translateY(-50px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  /* Wishlist button - active state */
  #WishlistButton-diamond.dp-wishlisted {
    background: #c9a961;
    border-color: #c9a961;
    color: #fff;
  }
  #WishlistButton-diamond.dp-wishlisted svg {
    fill: #fff;
    stroke: #fff;
  }

  /* Floating wishlist tray */
  #dp-wishlist-tray {
    position: fixed;
    bottom: -90px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 99999;
    transition: bottom 0.3s ease;
    white-space: nowrap;
  }
  #dp-wishlist-tray.visible { bottom: 24px; }
  .dp-tray-inner {
    display: flex;
    align-items: center;
    gap: 14px;
    background: #0a1428;
    color: #fff;
    padding: 14px 22px;
    border-radius: 50px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }
  .dp-tray-icon { font-size: 20px; color: #c9a961; }
  .dp-tray-text { font-size: 14px; font-weight: 500; }
  .dp-tray-btn {
    background: #c9a961;
    color: #0a1428;
    border: none;
    border-radius: 50px;
    padding: 9px 22px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    cursor: pointer;
  }
  .dp-tray-btn:hover { background: #e0c07a; }
  .dp-tray-clear {
    background: none;
    border: none;
    color: rgba(255,255,255,0.5);
    font-size: 22px;
    line-height: 1;
    cursor: pointer;
    padding: 0 2px;
  }
  .dp-tray-clear:hover { color: #fff; }

  /* Wishlist items inside inquiry modal */
  .dp-wishlist-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .dp-wishlist-list li {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 0;
    border-bottom: 1px solid #eee;
    font-size: 13px;
  }
  .dp-wishlist-list li:last-child { border-bottom: none; }
  .dp-wl-name { flex: 1; color: #333; }
  .dp-wl-price { font-weight: 600; color: #111; flex-shrink: 0; }
  .dp-wl-remove {
    background: none;
    border: none;
    color: #bbb;
    font-size: 18px;
    cursor: pointer;
    padding: 0 2px;
    flex-shrink: 0;
  }
  .dp-wl-remove:hover { color: #e74c3c; }

  /* Accordion Styles */
  .diamond-accordion-item {
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    margin-bottom: 12px;
    background: #fafafa;
    overflow: hidden;
  }
  
  .diamond-accordion-summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    list-style: none;
    padding: 18px 24px;
    background: #fafafa;
    transition: background 0.2s ease;
  }
  
  .diamond-accordion-summary::-webkit-details-marker {
    display: none;
  }
  
  .diamond-accordion-summary:hover {
    background: #f5f5f5;
  }
  
  .diamond-accordion-item[open] .diamond-accordion-summary {
    background: #fff;
    border-bottom: 1px solid #e5e5e5;
  }
  
  .diamond-accordion-item .accordion__content {
    padding: 0;
    background: #fff;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>


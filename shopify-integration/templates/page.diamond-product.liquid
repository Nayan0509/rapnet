<script>
// Tab functionality
function openCity(evt, cityName) {
  var i, tabcontent, tablinks;
  tabcontent = document.getElementsByClassName("tabcontent");
  for (i = 0; i < tabcontent.length; i++) {
    tabcontent[i].style.display = "none";
  }
  tablinks = document.getElementsByClassName("tablinks");
  for (i = 0; i < tablinks.length; i++) {
    tablinks[i].className = tablinks[i].className.replace(" active", "");
  }
  document.getElementById(cityName).style.display = "block";
  evt.currentTarget.className += " active";
}

// ── Wishlist (localStorage, survives page navigation) ──────────────────────
var DP_WL_KEY = 'dp_diamond_wishlist';

function dpGetWL() {
  try { return JSON.parse(localStorage.getItem(DP_WL_KEY)) || {}; } catch(e) { return {}; }
}
function dpSaveWL(wl) { localStorage.setItem(DP_WL_KEY, JSON.stringify(wl)); }

function dpUpdateTray() {
  var count = Object.keys(dpGetWL()).length;
  var tray  = document.getElementById('dp-wishlist-tray');
  var el    = document.getElementById('dp-wl-count');
  if (tray) tray.classList.toggle('visible', count > 0);
  if (el)   el.textContent = count;
}

function dpSyncBtn() {
  var diamond = window.currentDiamond;
  if (!diamond) return;
  var inList = !!dpGetWL()[diamond.diamond_id];
  var btn    = document.getElementById('WishlistButton-diamond');
  var label  = document.getElementById('wishlist-btn-label');
  var icon   = document.getElementById('wishlist-btn-icon');
  if (!btn) return;
  btn.classList.toggle('dp-wishlisted', inList);
  if (label) label.textContent = inList ? 'Remove from Wishlist' : 'Add to Wishlist';
  if (icon)  { icon.setAttribute('fill', inList ? 'currentColor' : 'none'); }
}

window.dpToggleWishlist = function() {
  var diamond = window.currentDiamond;
  if (!diamond) return;
  var wl = dpGetWL();
  if (wl[diamond.diamond_id]) {
    delete wl[diamond.diamond_id];
  } else {
    wl[diamond.diamond_id] = {
      diamond_id: diamond.diamond_id,
      lab:        diamond.lab,
      size:       diamond.size,
      color:      diamond.color,
      clarity:    diamond.clarity,
      cut:        diamond.cut,
      shape:      diamond.shape,
      stock_num:  diamond.stock_num,
      total_sales_price_in_currency: diamond.total_sales_price_in_currency,
      total_sales_price:             diamond.total_sales_price,
      image_file: diamond.image_file
    };
  }
  dpSaveWL(wl);
  dpSyncBtn();
  dpUpdateTray();
  
  // Trigger header badge update
  if (window.updateWishlistBadge) {
    window.updateWishlistBadge();
  }
  window.dispatchEvent(new Event('wishlistUpdated'));
};

window.dpRemoveFromWL = function(id) {
  var wl = dpGetWL();
  delete wl[id];
  dpSaveWL(wl);
  dpSyncBtn();
  dpUpdateTray();
  
  // Trigger header badge update
  if (window.updateWishlistBadge) {
    window.updateWishlistBadge();
  }
  window.dispatchEvent(new Event('wishlistUpdated'));
  
  dpOpenWishlistInquiry(); // refresh modal list
};

window.dpClearWishlist = function() {
  dpSaveWL({});
  dpSyncBtn();
  dpUpdateTray();
  
  // Trigger header badge update
  if (window.updateWishlistBadge) {
    window.updateWishlistBadge();
  }
  window.dispatchEvent(new Event('wishlistUpdated'));
};

window.dpOpenWishlistInquiry = function() {
  var items = Object.values(dpGetWL());
  if (!items.length) return;

  // Store items for the submit interceptor
  window._dpWishlistItems = items;

  // Build diamond list in the info box
  var infoBox = document.getElementById('inquiry-diamond-info');
  if (infoBox) {
    var rows = items.map(function(d) {
      var name  = [d.lab, d.size ? d.size + ' ct' : '', d.color + '-' + d.clarity, d.shape].filter(Boolean).join(' ');
      var price = d.total_sales_price_in_currency || d.total_sales_price || 0;
      return '<li>'
        + '<span class="dp-wl-name">' + name + '</span>'
        + '<span class="dp-wl-price">Rs. ' + price.toLocaleString('en-IN') + '</span>'
        + '<button class="dp-wl-remove" onclick="dpRemoveFromWL(' + d.diamond_id + ')" title="Remove">&times;</button>'
        + '</li>';
    }).join('');
    infoBox.innerHTML = '<h3>Selected Diamonds (' + items.length + ')</h3><ul class="dp-wishlist-list">' + rows + '</ul>';
  }

  // Reset form first, then pre-fill message
  var form    = document.getElementById('inquiry-form');
  var success = document.getElementById('inquiry-success-message');
  var error   = document.getElementById('inquiry-error-message');
  if (form)    form.reset();
  if (success) success.style.display = 'none';
  if (error)   error.style.display   = 'none';

  var msgField = document.getElementById('inquiry-message');
  if (msgField) {
    msgField.value = 'I am interested in the following diamonds:\n\n' + items.map(function(d, i) {
      var name  = [d.lab, d.size ? d.size + ' ct' : '', d.color + '-' + d.clarity, d.shape].filter(Boolean).join(' ');
      var price = d.total_sales_price_in_currency || d.total_sales_price || 0;
      return (i + 1) + '. ' + name + ' — Rs. ' + price.toLocaleString('en-IN');
    }).join('\n');
  }

  var modal = document.getElementById('inquiry-modal');
  if (modal) { modal.classList.add('active'); document.body.style.overflow = 'hidden'; }
};

// Intercept form submit in capture phase — runs before diamond-product.js handler
// Only takes over when wishlist mode is active (_dpWishlistItems is set)
document.addEventListener('DOMContentLoaded', function() {
  dpUpdateTray();
  
  // Trigger initial header badge update
  if (window.updateWishlistBadge) {
    window.updateWishlistBadge();
  }
  
  var t = setInterval(function() {
    if (window.currentDiamond) { clearInterval(t); dpSyncBtn(); }
  }, 150);

  // Check if we should open wishlist inquiry modal automatically
  var urlParams = new URLSearchParams(window.location.search);
  if (urlParams.get('inquiry') === 'wishlist' && sessionStorage.getItem('wishlistInquiry')) {
    sessionStorage.removeItem('wishlistInquiry');
    setTimeout(function() {
      dpOpenWishlistInquiry();
    }, 500);
  }

  // Clear wishlist mode when regular Send Inquiry button is clicked
  var inquiryBtn = document.getElementById('InquiryButton-diamond');
  if (inquiryBtn) {
    inquiryBtn.addEventListener('click', function() {
      window._dpWishlistItems = null;
    });
  }

  var form = document.getElementById('inquiry-form');
  if (!form) return;

  form.addEventListener('submit', function(e) {
    var items = window._dpWishlistItems;
    if (!items || !items.length) return; // single diamond — let diamond-product.js handle it

    e.preventDefault();
    e.stopImmediatePropagation();

    var BACKEND_URL = window.DIAMOND_BACKEND_URL || 'https://rapnet.vercel.app';
    var CURRENCY    = 'Rs.';
    var formData    = new FormData(form);
    var submitBtn   = document.getElementById('inquiry-submit-btn');
    var successMsg  = document.getElementById('inquiry-success-message');
    var errorMsg    = document.getElementById('inquiry-error-message');

    var totalValue = items.reduce(function(sum, d) {
      return sum + (d.total_sales_price_in_currency || d.total_sales_price || 0);
    }, 0);

    var diamondLines = items.map(function(d, i) {
      var name = [d.lab, (d.size || 'N/A') + ' Carat', d.color + '-' + d.clarity, d.shape].filter(Boolean).join(' ');
      var price = d.total_sales_price_in_currency || d.total_sales_price || 0;
      return (i + 1) + '. ' + name + ' (SKU: ' + (d.stock_num || d.diamond_id) + ') — ' + CURRENCY + price.toLocaleString('en-IN');
    }).join('\n');

    var first = items[0];
    var inquiryData = {
      customer: {
        name:  formData.get('name'),
        email: formData.get('email'),
        phone: formData.get('phone')
      },
      diamond: {
        id:             'WISHLIST',
        name:           items.length + ' Diamonds — Wishlist Inquiry',
        sku:            items.map(function(d){ return d.stock_num || d.diamond_id; }).join(', '),
        shape:          items.map(function(d){ return d.shape; }).join(', '),
        size:           items.map(function(d){ return d.size; }).join(', '),
        color:          items.map(function(d){ return d.color; }).join(', '),
        clarity:        items.map(function(d){ return d.clarity; }).join(', '),
        cut:            items.map(function(d){ return d.cut || 'N/A'; }).join(', '),
        polish:         first.polish   || 'N/A',
        symmetry:       first.symmetry || 'N/A',
        lab:            items.map(function(d){ return d.lab; }).join(', '),
        cert_num:       'See individual diamonds',
        price:          totalValue,
        priceFormatted: CURRENCY + totalValue.toLocaleString('en-IN'),
        image:          null
      },
      quantity:            1,
      totalPrice:          totalValue,
      totalPriceFormatted: CURRENCY + totalValue.toLocaleString('en-IN'),
      message:             'SELECTED DIAMONDS:\n' + diamondLines
        + (formData.get('message') ? '\n\nADDITIONAL NOTE:\n' + formData.get('message') : '')
    };

    if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Sending...'; }

    fetch(BACKEND_URL + '/api/diamonds/send-inquiry', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify(inquiryData)
    })
    .then(function(res) {
      if (!res.ok) throw new Error('Failed');
      return res.json();
    })
    .then(function() {
      // Clear wishlist on success
      window._dpWishlistItems = null;
      dpSaveWL({});
      dpSyncBtn();
      dpUpdateTray();
      
      // Trigger header badge update
      if (window.updateWishlistBadge) {
        window.updateWishlistBadge();
      }
      window.dispatchEvent(new Event('wishlistUpdated'));

      if (successMsg) { successMsg.textContent = 'Your inquiry has been sent successfully! We\'ll get back to you soon.'; successMsg.style.display = 'block'; }
      if (form)       form.style.display = 'none';

      setTimeout(function() {
        var modal = document.getElementById('inquiry-modal');
        if (modal) { modal.classList.remove('active'); document.body.style.overflow = ''; }
        if (form)  { form.style.display = 'block'; form.reset(); }
        if (successMsg) successMsg.style.display = 'none';
        if (submitBtn)  { submitBtn.disabled = false; submitBtn.textContent = 'Send Inquiry'; }
      }, 3000);
    })
    .catch(function() {
      if (errorMsg)  { errorMsg.textContent = 'Failed to send inquiry. Please try again.'; errorMsg.style.display = 'block'; }
      if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Send Inquiry'; }
    });
  }, true); // capture phase
});
</script>
